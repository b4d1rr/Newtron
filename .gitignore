# MSVC Windows builds of rustc generate these
*.pdb

# Generated by cargo mutants
**/mutants.out*/

# --- Project Specific (Newtron) ---
# Prevents leaking your local file index or AI session data
*.db
*.db-journal
*.sqlite
*.sqlite-journal
secrets.json

# Logs and temp files
logs/
logs
*.log
temp/

# --- Testing ---
coverage/
.nyc_output
